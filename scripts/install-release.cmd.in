@echo off
setlocal
title Maya MCP Installer

echo.
echo Maya MCP Installer
echo ------------------
echo This installs Maya MCP for your Windows user. Administrator access is not required.
echo.

if exist "%~dp0Install-MayaMcp.ps1" goto run_extracted

echo Windows opened only the launcher from inside the ZIP.
echo Downloading and verifying the complete Maya MCP package...
echo.
set "MAYA_MCP_BOOTSTRAP_LAUNCHER=%~f0"
powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -Command "$source = Get-Content -LiteralPath $env:MAYA_MCP_BOOTSTRAP_LAUNCHER -Raw; $marker = '# MAYA_MCP_POWERSHELL_BOOTSTRAP'; $offset = $source.LastIndexOf($marker, [StringComparison]::Ordinal); if ($offset -lt 0) { throw 'The installer bootstrap is damaged.' }; & ([ScriptBlock]::Create($source.Substring($offset + $marker.Length)))"
set "installer_exit=%ERRORLEVEL%"
goto report

:run_extracted
powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File "%~dp0Install-MayaMcp.ps1" %*
set "installer_exit=%ERRORLEVEL%"

:report
echo.
if not "%installer_exit%"=="0" (
    echo Installation failed. Read the message above, fix the problem, and run this installer again.
) else (
    echo Installation complete. You can open Maya now.
)

if not defined MAYA_MCP_INSTALLER_NO_PAUSE pause
exit /b %installer_exit%

# MAYA_MCP_POWERSHELL_BOOTSTRAP
$ErrorActionPreference = 'Stop'
$expectedVersion = '__MAYA_MCP_VERSION__'
$expectedAssetName = '__MAYA_MCP_ASSET__'
$repository = 'parodyband/maya-mcp'
$maximumArchiveBytes = 128MB
$maximumExtractedBytes = 512MB
$maximumEntries = 4096
$headers = @{
    Accept = 'application/vnd.github+json'
    'User-Agent' = "maya-mcp-installer/$expectedVersion"
    'X-GitHub-Api-Version' = '2022-11-28'
}

function Get-Sha256([string]$Path) {
    return (Get-FileHash -LiteralPath $Path -Algorithm SHA256).Hash.ToLowerInvariant()
}

function Assert-Sha256([string]$Path, [string]$Expected, [string]$Label) {
    $normalized = $Expected.Trim().ToLowerInvariant()
    if ($normalized.StartsWith('sha256:')) { $normalized = $normalized.Substring(7) }
    if ($normalized -notmatch '^[0-9a-f]{64}$') { throw "$Label has an invalid SHA-256 digest." }
    $actual = Get-Sha256 $Path
    if ($actual -ne $normalized) { throw "$Label failed SHA-256 verification." }
}

function Expand-VerifiedArchive([string]$Archive, [string]$Destination) {
    Add-Type -AssemblyName System.IO.Compression.FileSystem
    $zip = [System.IO.Compression.ZipFile]::OpenRead($Archive)
    try {
        if ($zip.Entries.Count -gt $maximumEntries) { throw 'The release archive contains too many files.' }
        $root = [System.IO.Path]::GetFullPath($Destination).TrimEnd('\') + '\'
        [long]$expandedBytes = 0
        foreach ($entry in $zip.Entries) {
            $expandedBytes += [long]$entry.Length
            if ($expandedBytes -gt $maximumExtractedBytes) { throw 'The release archive is too large when extracted.' }
            $normalizedName = $entry.FullName.Replace('\', '/')
            if ($normalizedName.Contains(':') -or $normalizedName.StartsWith('/') -or
                @($normalizedName.Split('/') | Where-Object { $_ -eq '..' }).Count -gt 0) {
                throw 'The release archive contains an unsafe path.'
            }
            $entryPath = [System.IO.Path]::GetFullPath((Join-Path $Destination $entry.FullName))
            if (-not $entryPath.StartsWith($root, [System.StringComparison]::OrdinalIgnoreCase)) {
                throw 'The release archive contains a path outside its package.'
            }
        }
    } finally {
        $zip.Dispose()
    }
    [System.IO.Compression.ZipFile]::ExtractToDirectory($Archive, $Destination)
}

$bootstrapRoot = Join-Path ([System.IO.Path]::GetTempPath()) (
    "maya-mcp-installer-$expectedVersion-$PID-$([guid]::NewGuid().ToString('N'))"
)
$archivePath = Join-Path $bootstrapRoot $expectedAssetName
$extractPath = Join-Path $bootstrapRoot 'release'
New-Item -ItemType Directory -Force -Path $extractPath | Out-Null

try {
    if ($env:MAYA_MCP_INSTALLER_ARCHIVE) {
        $sourceArchive = [System.IO.Path]::GetFullPath($env:MAYA_MCP_INSTALLER_ARCHIVE)
        if (-not (Test-Path -LiteralPath $sourceArchive -PathType Leaf)) {
            throw 'MAYA_MCP_INSTALLER_ARCHIVE does not point to a release ZIP.'
        }
        Copy-Item -LiteralPath $sourceArchive -Destination $archivePath
        if ($env:MAYA_MCP_INSTALLER_SHA256) {
            Assert-Sha256 $archivePath $env:MAYA_MCP_INSTALLER_SHA256 'The supplied release archive'
        }
    } else {
        $releaseUri = "https://api.github.com/repos/$repository/releases/tags/v$expectedVersion"
        $release = Invoke-RestMethod -Uri $releaseUri -Headers $headers
        if ([string]$release.tag_name -ne "v$expectedVersion" -or $release.draft -or $release.prerelease) {
            throw "GitHub did not return the stable v$expectedVersion release."
        }

        $manifestAssets = @($release.assets | Where-Object { $_.name -eq 'release-manifest.json' })
        $packageAssets = @($release.assets | Where-Object { $_.name -eq $expectedAssetName })
        if ($manifestAssets.Count -ne 1 -or $packageAssets.Count -ne 1) {
            throw 'The GitHub release does not contain the expected Maya MCP package.'
        }
        $packageAsset = $packageAssets[0]
        if ([long]$packageAsset.size -le 0 -or [long]$packageAsset.size -gt $maximumArchiveBytes) {
            throw 'The GitHub release package size is invalid.'
        }

        $manifestPath = Join-Path $bootstrapRoot 'release-manifest.json'
        Invoke-WebRequest -UseBasicParsing -Uri $manifestAssets[0].browser_download_url -Headers $headers -OutFile $manifestPath
        $manifest = Get-Content -LiteralPath $manifestPath -Raw | ConvertFrom-Json
        if ([int]$manifest.schema_version -ne 1 -or [string]$manifest.repository -ne $repository -or
            [string]$manifest.version -ne $expectedVersion) {
            throw 'The release manifest identity is invalid.'
        }
        $manifestMatches = @($manifest.assets | Where-Object { $_.name -eq $expectedAssetName })
        if ($manifestMatches.Count -ne 1) { throw 'The release manifest does not describe the expected package.' }
        $manifestAsset = $manifestMatches[0]
        if ([long]$manifestAsset.size -ne [long]$packageAsset.size) {
            throw 'GitHub and the release manifest disagree about the package size.'
        }
        if ($packageAsset.digest -and
            [string]$packageAsset.digest -ne "sha256:$([string]$manifestAsset.sha256)" ) {
            throw 'GitHub and the release manifest disagree about the package digest.'
        }

        Invoke-WebRequest -UseBasicParsing -Uri $packageAsset.browser_download_url -Headers $headers -OutFile $archivePath
        if ((Get-Item -LiteralPath $archivePath).Length -ne [long]$manifestAsset.size) {
            throw 'The downloaded package size is invalid.'
        }
        Assert-Sha256 $archivePath ([string]$manifestAsset.sha256) 'The downloaded release archive'
    }

    if ((Get-Item -LiteralPath $archivePath).Length -gt $maximumArchiveBytes) {
        throw 'The release archive exceeds the installer size limit.'
    }
    Expand-VerifiedArchive $archivePath $extractPath

    $packageManifestPath = Join-Path $extractPath 'package-manifest.json'
    $installerPath = Join-Path $extractPath 'Install-MayaMcp.ps1'
    if (-not (Test-Path -LiteralPath $packageManifestPath -PathType Leaf) -or
        -not (Test-Path -LiteralPath $installerPath -PathType Leaf)) {
        throw 'The release archive is missing its installer files.'
    }
    $packageManifest = Get-Content -LiteralPath $packageManifestPath -Raw | ConvertFrom-Json
    if ([string]$packageManifest.version -ne $expectedVersion) {
        throw 'The release archive version does not match this launcher.'
    }
    $expectedFolder = "maya-mcp-$expectedVersion-maya$([string]$packageManifest.maya_target)"
    if (-not (Test-Path -LiteralPath (Join-Path $extractPath "$expectedFolder\plug-ins\maya_mcp.mll") -PathType Leaf)) {
        throw 'The release archive plug-in payload is incomplete.'
    }

    $installArguments = @{}
    if ($env:MAYA_MCP_INSTALLER_MODULES_DIRECTORY) {
        $installArguments.ModulesDirectory = $env:MAYA_MCP_INSTALLER_MODULES_DIRECTORY
    }
    if ($env:MAYA_MCP_INSTALLER_MAYA_LOCATION) {
        $installArguments.MayaLocation = $env:MAYA_MCP_INSTALLER_MAYA_LOCATION
    }
    if ($env:MAYA_MCP_INSTALLER_ALLOW_RUNNING -eq '1') {
        $installArguments.AllowMayaRunning = $true
    }
    & $installerPath @installArguments
} finally {
    if (Test-Path -LiteralPath $bootstrapRoot) {
        Remove-Item -LiteralPath $bootstrapRoot -Recurse -Force -ErrorAction SilentlyContinue
    }
}
